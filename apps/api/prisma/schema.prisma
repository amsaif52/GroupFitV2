generator client {
  provider = "prisma-client-js"
}

// Run with: npx prisma db seed

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?        // display name (signup / profile)
  googleId      String?        @unique @map("google_id")
  appleId       String?        @unique @map("apple_id")
  role          String         // admin | trainer | customer
  locale        String?        @default("en")
  countryCode   String?        @map("country_code") // ISO 3166-1 alpha-2 (e.g. US, GB) for payments/location
  state         String?       // state / province / region (e.g. CA, NSW)
  trainerCanSetOwnPrice Boolean? @map("trainer_can_set_own_price") // when true, trainer can set price per activity; else use activity default
  phone         String?        @unique // for OTP login
  otp           String?       // 4-digit OTP
  otpSentAt     DateTime?     @map("otp_sent_at") // expiry check (5 min)
  // Customer profile (optional for all users)
  avatarUrl     String?        @map("avatar_url") @db.Text
  gender        String?        // e.g. male, female, other, prefer_not_to_say
  dateOfBirth   DateTime?     @map("date_of_birth")
  heightCm      Float?         @map("height_cm")
  weightKg      Float?         @map("weight_kg")
  preExistingConditions String? @map("pre_existing_conditions") @db.Text
  // Trainer profile (address, bio, etc.)
  streetLine1     String?   @map("street_line1")
  streetLine2     String?   @map("street_line2")
  city            String?
  postalCode      String?   @map("postal_code")
  languageSpoken  String?   @map("language_spoken") @db.Text
  about           String?   @db.Text // trainer bio
  yearsExperience Int?      @map("years_experience")
  gstRegistered   Boolean?  @map("gst_registered")
  trainerProfileCompleteAt DateTime? @map("trainer_profile_complete_at") // set when trainer fills required profile (excl. additional images/social); visibility to customers requires this + isActive
  isActive      Boolean       @default(true) @map("is_active") // admin can deactivate customer/trainer; for trainers, admin sets true after profile complete to make visible
  isVerified    Boolean?      @default(false) @map("is_verified") // admin can set trainer verified/unverified (e.g. identity/credentials verified)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  conversations Conversation[]
  sessionsAsCustomer Session[]  @relation("SessionCustomer")
  sessionsAsTrainer  Session[]  @relation("SessionTrainer")
  supportTickets     SupportTicket[]
  favouriteActivities CustomerFavouriteActivity[]
  favouriteTrainers       CustomerFavouriteTrainer[] @relation("FavouriteTrainerCustomer")
  favouritedByCustomers   CustomerFavouriteTrainer[] @relation("FavouriteTrainerTrainer")
  notifications      Notification[]
  trainerAvailabilities TrainerAvailability[]
  referralsMade         Referral[]  @relation("Referrer")
  referredBy            Referral?   @relation("Referred")
  certificates          TrainerCertificate[]
  reviewsGiven         Review[]    @relation("Reviewer")
  reviewsReceived      Review[]    @relation("ReviewedTrainer")
  trainerActivities    TrainerActivity[]
  socialLinks          TrainerSocialLink?
  additionalImages     TrainerAdditionalImage[]
  groupsOwned          Group[]         @relation("GroupOwner")
  groupMemberships     GroupMember[]   @relation("GroupMemberUser")
  bankDetails          TrainerBankDetail?
  serviceAreas         TrainerServiceArea[]
  customerLocations    CustomerLocation[]
  groupInvitesByPhoneSent GroupInviteByPhone[] @relation("GroupInviteByPhoneInvitedBy")
  toasts              Toast[]
  activitiesCreated    Activity[]         @relation("ActivityCreatedBy")
  activitiesUpdated    Activity[]         @relation("ActivityUpdatedBy")
  countriesUpdated     Country[]          @relation("CountryUpdatedBy")
  languagesUpdated     Language[]         @relation("LanguageUpdatedBy")
  statesUpdated        State[]            @relation("StateUpdatedBy")
  contactLinksUpdated  ContactLink[]      @relation("ContactLinkUpdatedBy")
  activityCategoriesUpdated ActivityCategory[] @relation("ActivityCategoryUpdatedBy")
}

model TrainerSocialLink {
  id         String   @id @default(cuid())
  trainerId  String   @map("trainer_id")
  trainer    User     @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  facebookId String?  @map("facebook_id")
  instagramId String? @map("instagram_id")
  tiktokId   String?  @map("tiktok_id")
  twitterId  String?  @map("twitter_id")
  youtubeId  String?  @map("youtube_id")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([trainerId])
  @@map("trainer_social_link")
}

model TrainerAdditionalImage {
  id        String   @id @default(cuid())
  trainerId String   @map("trainer_id")
  trainer   User     @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  imageUrl  String   @map("image_url") @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("trainer_additional_image")
}

// Admin master data: countries (name, ISD code).
model Country {
  id          String   @id @default(cuid())
  name        String
  isdCode     String   @map("isd_code") // e.g. "+1"
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("CountryUpdatedBy", fields: [updatedById], references: [id])
  states      State[]
  @@map("country")
}

// Admin master data: supported languages.
model Language {
  id          String   @id @default(cuid())
  name        String
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("LanguageUpdatedBy", fields: [updatedById], references: [id])
  @@map("language")
}

// Admin master data: states/provinces (optional link to country).
model State {
  id          String   @id @default(cuid())
  name        String
  countryId   String?  @map("country_id")
  country     Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("StateUpdatedBy", fields: [updatedById], references: [id])
  @@map("state")
}

// Admin: activity categories (e.g. Cardio and Endurance, Individual Sports). Activity.activityGroup can match name.
model ActivityCategory {
  id          String   @id @default(cuid())
  name        String   // e.g. "Cardio and Endurance"
  iconUrl     String?  @map("icon_url") @db.Text // optional icon image URL
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("ActivityCategoryUpdatedBy", fields: [updatedById], references: [id])
  @@map("activity_category")
}

// Admin: contact us entries (name, link, optional icon URL).
model ContactLink {
  id          String   @id @default(cuid())
  name        String   // e.g. "Customer Service", "Facebook"
  link        String   @db.Text // URL or mailto:
  iconUrl     String?  @map("icon_url") @db.Text // optional icon image URL
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("ContactLinkUpdatedBy", fields: [updatedById], references: [id])
  @@map("contact_link")
}

// When a user signs up with a referral code, create a Referral linking referrer and referred user.
model Referral {
  id             String   @id @default(cuid())
  referrerId     String   @map("referrer_id")
  referredUserId String   @unique @map("referred_user_id")
  createdAt      DateTime @default(now())
  referrer       User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser   User     @relation("Referred", fields: [referredUserId], references: [id], onDelete: Cascade)
  @@unique([referrerId, referredUserId])
  @@map("referral")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?  @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  @@map("notification")
}

// Trainer weekly availability slots (dayOfWeek 0=Sun..6=Sat, startTime/endTime HH:mm).
// Optional serviceAreaId links slot to a service area (location).
model TrainerAvailability {
  id            String             @id @default(cuid())
  trainerId     String             @map("trainer_id")
  trainer       User               @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  serviceAreaId String?            @map("service_area_id")
  serviceArea   TrainerServiceArea? @relation(fields: [serviceAreaId], references: [id], onDelete: SetNull)
  dayOfWeek     Int                @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime     String             @map("start_time")   // "09:00"
  endTime       String             @map("end_time")     // "17:00"
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  @@map("trainer_availability")
}

model CustomerFavouriteActivity {
  id          String   @id @default(cuid())
  customerId  String   @map("customer_id")
  activityCode String  @map("activity_code") // matches ACTIVITY_TYPES.code
  createdAt   DateTime @default(now())
  customer    User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@unique([customerId, activityCode])
  @@map("customer_favourite_activity")
}

model CustomerFavouriteTrainer {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  trainerId  String   @map("trainer_id")
  createdAt  DateTime @default(now())
  customer   User     @relation("FavouriteTrainerCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  trainer    User     @relation("FavouriteTrainerTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  @@unique([customerId, trainerId])
  @@map("customer_favourite_trainer")
}

// Customer-created groups (e.g. for group sessions or invites).
model Group {
  id        String       @id @default(cuid())
  ownerId   String       @map("owner_id")
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  owner     User         @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   GroupMember[]
  invitesByPhone GroupInviteByPhone[]
  @@map("customer_group")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation("GroupMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  @@unique([groupId, userId])
  @@map("group_member")
}

// Group invite by phone: status PENDING until invitee signs up and accepts (APPROVED) or declines (REJECTED).
model GroupInviteByPhone {
  id          String   @id @default(cuid())
  groupId     String   @map("group_id")
  phone       String
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  invitedById String   @map("invited_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy   User     @relation("GroupInviteByPhoneInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  @@unique([groupId, phone])
  @@map("group_invite_by_phone")
}

model Session {
  id          String   @id @default(cuid())
  customerId String   @map("customer_id")
  trainerId   String   @map("trainer_id")
  customer    User     @relation("SessionCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  trainer     User     @relation("SessionTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  activityName String? @map("activity_name") // e.g. "Yoga", "HIIT"
  scheduledAt DateTime @map("scheduled_at")
  status      String   // scheduled | completed | cancelled
  amountCents Int?     @map("amount_cents") // paid amount for earnings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trainerSessionLocation TrainerSessionLocation?
}

// Trainer's last-reported location for a session (only valid within 30 mins before scheduledAt). Customer can view.
model TrainerSessionLocation {
  id         String   @id @default(cuid())
  sessionId  String   @unique @map("session_id")
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  trainerId  String   @map("trainer_id")
  latitude   Float
  longitude  Float
  updatedAt  DateTime @updatedAt
  @@map("trainer_session_location")
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  message   String   @db.Text
  status    String   // open | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Discount {
  id                   String    @id @default(cuid())
  code                 String    @unique
  type                 String    // percent | fixed
  value                Decimal   @db.Decimal(10, 2)
  validFrom            DateTime? @map("valid_from")
  validTo              DateTime? @map("valid_to")
  isActive             Boolean   @default(true) @map("is_active")
  allowedDays          String?   @map("allowed_days") @db.Text // comma-separated 0-6 (0=Sun, 6=Sat); null/empty = all days
  singleUsePerCustomer Boolean   @default(false) @map("single_use_per_customer")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  vouchers             Voucher[]
}

// Vouchers generated from a discount for distribution to people/organizations (analytics).
model Voucher {
  id             String    @id @default(cuid())
  discountId     String    @map("discount_id")
  code           String    @unique // unique voucher code (e.g. SAVE10-X7K2M)
  recipientName  String?   @map("recipient_name") // person or org for analytics
  recipientOrg   String?   @map("recipient_org")
  createdAt      DateTime  @default(now())
  usedAt         DateTime? @map("used_at")
  discount       Discount  @relation(fields: [discountId], references: [id], onDelete: Cascade)
  @@map("voucher")
}

// Activity types (master data). Admin CRUD; customer/trainer read via fetchAllActivity.
model Activity {
  id                  String    @id @default(cuid())
  code                String    @unique
  name                String
  description         String?   @db.Text
  defaultPriceCents   Int?      @map("default_price_cents") // default session price when trainer does not set own
  logoUrl             String?   @map("logo_url")
  activityGroup       String?   @map("activity_group")
  trainerSharePercent Int?      @map("trainer_share_percent") // 0-100
  status              String?   @default("active") // active | inactive
  createdById         String?   @map("created_by_id")
  updatedById         String?   @map("updated_by_id")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  createdBy           User?     @relation("ActivityCreatedBy", fields: [createdById], references: [id])
  updatedBy           User?     @relation("ActivityUpdatedBy", fields: [updatedById], references: [id])
  @@map("activity")
}

// Which activities a trainer offers (activityCode matches Activity.code).
model TrainerActivity {
  id           String   @id @default(cuid())
  trainerId    String   @map("trainer_id")
  activityCode String   @map("activity_code")
  priceCents   Int?     @map("price_cents") // trainer override; only used when user.trainerCanSetOwnPrice is true
  createdAt    DateTime @default(now())
  trainer      User     @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  @@unique([trainerId, activityCode])
  @@map("trainer_activity")
}

// Trainer certificates (name, issuing org, issued date, optional document URL).
model TrainerCertificate {
  id                   String    @id @default(cuid())
  trainerId            String    @map("trainer_id")
  trainer              User      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  name                 String    // e.g. "CPR", "NASM"
  issuingOrganization  String?  @map("issuing_organization")
  issuedAt             DateTime? @map("issued_at")
  credentialId         String?   @map("credential_id")
  documentUrl          String?   @map("document_url") @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  @@map("trainer_certificate")
}

// Trainer service areas (where trainer offers sessions; can toggle on/off).
model TrainerServiceArea {
  id             String                @id @default(cuid())
  trainerId      String                @map("trainer_id")
  trainer        User                  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  label          String                // e.g. "Downtown", "North Side"
  address        String?               @db.Text
  latitude       Float?
  longitude      Float?
  radiusKm       Float?                @map("radius_km")
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  availabilities TrainerAvailability[]
  @@map("trainer_service_area")
}

// Trainer bank details for payouts (store only masked/last4; full details via Stripe Connect in production).
model TrainerBankDetail {
  id                String   @id @default(cuid())
  trainerId         String   @unique @map("trainer_id")
  trainer           User     @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  accountHolderName String   @map("account_holder_name")
  bankName          String?  @map("bank_name")
  last4             String   @map("last4")   // last 4 digits of account
  routingLast4      String?  @map("routing_last4") // last 4 of routing (optional)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@map("trainer_bank_detail")
}

// Customer reviews for a trainer (rating 1-5, optional comment and session link).
model Review {
  id         String   @id @default(cuid())
  trainerId  String   @map("trainer_id")
  customerId String   @map("customer_id")
  sessionId  String?  @map("session_id")
  rating     Int      // 1-5
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  trainer    User     @relation("ReviewedTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  customer   User     @relation("Reviewer", fields: [customerId], references: [id], onDelete: Cascade)
  @@map("review")
}

// Admin master data: FAQ entries.
model Faq {
  id        String   @id @default(cuid())
  question  String   @db.Text
  answer    String   @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  role      String?  // e.g. "all" | "customer" | "trainer" – which audience sees this FAQ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("faq")
}

// Admin: misc key-value entries (name + type, e.g. for dropdowns or config).
model Misc {
  id        String   @id @default(cuid())
  name      String
  type      String   // e.g. "category", "tag" – to group misc entries
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("misc")
}

// Admin: key-value settings (e.g. contact_email, customize_dashboard JSON).
model ContactSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
  @@map("contact_setting")
}

// Feature flags (e.g. enable_google_login, enable_phone_otp). Fetched by login page before render.
model FeatureFlag {
  id        String   @id @default(cuid())
  name      String   @unique
  status    Boolean  @default(false)
  updatedAt DateTime @updatedAt
  @@map("feature_flag")
}

// Customer saved locations (e.g. for session booking).
model CustomerLocation {
  id            String   @id @default(cuid())
  customerId    String   @map("customer_id")
  customer      User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  label         String
  address       String?  @db.Text   // full formatted address for display
  streetLine1   String?  @map("street_line1")
  streetLine2   String?  @map("street_line2")
  city          String?
  stateProvince String?  @map("state_province")
  postalCode    String?  @map("postal_code")
  country       String?
  latitude      Float?
  longitude     Float?
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@map("customer_location")
}

// Per-user flags for modals/toasts (e.g. activities disclaimer seen).
model Toast {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String   // e.g. 'activities_disclaimer_seen'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, key])
  @@map("toast")
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user | assistant | system
  content        String       @db.Text
  createdAt      DateTime     @default(now())
}
