{
  "name": "groupfit",
  "version": "1.0.0",
  "private": true,
  "description": "GroupFit - Fitness platform with admin, trainer, and customer apps",
  "workspaces": [
    "apps/*",
    "packages/*",
    "shared"
  ],
  "scripts": {
    "dev:shared": "npm run dev --workspace=@groupfit/shared",
    "dev:api": "npm run dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "dev:web:fresh": "rm -rf apps/web/.next && npm run dev:web",
    "dev:customer-app": "npm run start --workspace=customer-app",
    "dev:trainer-app": "npm run start --workspace=trainer-app",
    "build:api": "npm run build --workspace=api",
    "build:web": "npm run build --workspace=web",
    "build:shared": "npm run build --workspace=@groupfit/shared",
    "storybook:shared": "npm run storybook --workspace=@groupfit/shared",
    "storybook:web": "npm run storybook --workspace=web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "e2e": "playwright test",
    "e2e:local": "playwright test -c playwright.config.local.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:creds": "playwright test -g \"test credentials\"",
    "prepare": "husky || true",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf build && rm -rf .next && rm -rf .expo && rm -rf .turbo && rm -rf .cache && rm -rf .storybook-static && rm -rf logs && rm -rf *.log && rm -rf pnpm-debug.log* && rm -rf yarn-debug.log* && rm -rf yarn-error.log* && rm -rf coverage && rm -rf .nyc_output && rm -rf playwright-report && rm -rf test-results && rm -rf blob-report && rm -rf .idea && rm -rf .vscode && rm -rf .swp && rm -rf .swo && rm -rf *~ && rm -rf .DS_Store && rm -rf Thumbs.db && rm -rf tmp && rm -rf temp && rm -rf .prisma"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
