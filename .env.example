# API (apps/api)
PORT=3001
# No password: use role name (e.g. postgres or your OS user). With password: postgresql://user:password@localhost:5432/groupfit
DATABASE_URL=postgresql://postgres@localhost:5432/groupfit
CORS_ORIGIN=http://localhost:3000
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
JWT_SECRET=your-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Web (apps/web) – use NEXT_PUBLIC_ for client-exposed vars
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Cloudinary (direct unsigned upload from web/RN). Only cloud name + preset go in client env.
# Do NOT put API secret in client env or in repo. Use API key/secret only in server-side code if needed.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dnxniyxsq
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=ml_default
